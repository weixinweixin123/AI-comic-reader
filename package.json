{
  "name": "ai-watchmate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "npm run desktop",
    "dev": "npm run desktop",
    "web": "concurrently \"npm:server\" \"npm:client\"",
    "client": "vite --host 127.0.0.1 --port 5173",
    "server": "node server/index.js",
    "desktop": "concurrently -k \"npm:server\" \"npm:client\" \"npm:electron:dev\"",
    "electron:dev": "wait-on http://127.0.0.1:5173/api/health http://127.0.0.1:5173 && electron . --dev-server",
    "electron": "npm run build && electron .",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "dist:win": "npm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.aiwatchmate.desktop",
    "productName": "AI Watchmate",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
